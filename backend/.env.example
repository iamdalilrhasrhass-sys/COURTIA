# Database
DATABASE_URL=postgresql://user:password@localhost:5432/crm_assurance
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_assurance
DB_USER=postgres
DB_PASSWORD=password

# Security
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook/telegram

# WhatsApp
WHATSAPP_API_KEY=your-whatsapp-key
WHATSAPP_PHONE_NUMBER=+33xxxxxxxxx

# Google APIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALENDAR_ID=your-calendar-id

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# OCR & Document Processing
GOOGLE_VISION_API_KEY=your-google-vision-key
TESSERACT_LANGUAGE=fra+eng

# Signature électronique
DOCUSIGN_INTEGRATION_KEY=your-key
DOCUSIGN_API_URL=https://demo.docusign.net

# APIs Assureurs (à configurer)
ASSUREUR_API_1_KEY=key
ASSUREUR_API_1_URL=https://api.assureur1.com

# Compliance
DDA_REPORT_EMAIL=dda@cabinet.com
GDPR_CONTACT_EMAIL=privacy@cabinet.com

# ==================== OPTION 4: AI COST MANAGEMENT ====================
# Anthropic API (Claude AI)
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...

# Telegram Alerts (for quota notifications)
TELEGRAM_ADMIN_CHAT_ID=123456789

# Environment
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
