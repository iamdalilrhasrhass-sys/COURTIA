# ============================================================
# COURTIA Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- JWT Authentication ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# --- Anthropic API (ARK) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe (paiements) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Telegram (onboarding) ---
TELEGRAM_BOT_TOKEN=your-t...oken

# --- SMS (TextBelt gratuit) ---
SMS_PROVIDER=textbelt
TEXTBELT_API_KEY=textbelt
# TEXTBELT_SELF_HOST_URL=      # Optionnel: auto-hébergement

# --- IMAP (Emails entrants — GRATUIT via Gmail) ---
IMAP_USER=arkcourtia@gmail.com
IMAP_PASSWORD=***
# IMAP_CHECK_INTERVAL_MINUTES=5   # Optionnel: intervalle de vérification

# --- Relances automatiques ---
# DISABLE_RELANCES=true            # Décommenter pour désactiver les relances auto

# --- Serveur ---
PORT=10000
NODE_ENV=production

# --- WhatsApp (Baileys — GRATUIT, auto-hébergé) ---
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=/root/courtia/whatsapp-session

# --- URLs ---
FRONTEND_URL=https://courtia.vercel.app
BACKEND_URL=https://courtia.onrender.com
